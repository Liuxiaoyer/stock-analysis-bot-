        # 发送微信通知
        wechat_sent = send_wechat_notification(report_content, WECHAT_TOKEN)
        
        # 最终状态报告
        print("\n" + "=" * 60)
        print("脚本执行完成:")
        print(f"✓ 股票数据获取: {'成功' if stock_data else '失败'}")
