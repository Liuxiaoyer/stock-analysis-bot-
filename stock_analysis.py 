    print("\n4. 获取股票数据...")
    
    # 您的持仓股票
    stocks = [
        {'code': '000001', 'name': '平安银行'},
        {'code': '002594', 'name': '比亚迪'},
        {'code': '603688', 'name': '石英股份'},
        {'code': '601318', 'name': '中国平安'},
        {'code': '601567', 'name': '三星医疗'}
    ]
    
    results = []
    
    try:
        # 尝试获取实时数据
        df = ak.stock_zh_a_spot_em()
        print(f"   获取到 {len(df)} 只股票数据")
        
        for stock in stocks:
            try:
                stock_df = df[df['代码'] == stock['code']]
                if not stock_df.empty:
                    data = stock_df.iloc[0]
                    stock_info = {
                        '名称': stock['name'],
                        '代码': stock['code'],
                        '最新价': float(data['最新价']),
                        '涨跌幅': float(data['涨跌幅']),
                        '涨跌额': float(data['涨跌额']),
                        '成交量': data['成交量'],
                        '成交额': data['成交额'],
                        '最高': float(data['最高']),
                        '最低': float(data['最低'])
                    }
                    results.append(stock_info)
                    print(f"   ✓ {stock['name']}: {stock_info['最新价']} ({stock_info['涨跌幅']:+.2f}%)")
                else:
                    print(f"   ✗ 未找到股票: {stock['code']}")
