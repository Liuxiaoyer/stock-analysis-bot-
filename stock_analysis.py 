    return results

def generate_report(stock_data):
    """生成分析报告"""
    print("\n5. 生成分析报告...")
    
    current_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
    
    report = f"""📈 股票分析报告
生成时间: {current_time}
================================

持仓股票分析:

"""
    
    for stock in stock_data:
        if stock['涨跌幅'] > 0:
            emoji = "📈"
        elif stock['涨跌幅'] < 0:
            emoji = "📉"
        else:
            emoji = "➖"
        
        report += f"{emoji} {stock['名称']}({stock['代码']})\n"
        report += f"   当前价格: {stock['最新价']:.2f} 元\n"
        report += f"   涨跌幅: {stock['涨跌幅']:+.2f}%\n"
        report += f"   成交额: {stock['成交额']} 元\n"
        report += f"   最高/最低: {stock['最高']:.2f}/{stock['最低']:.2f}\n"
        report += "-" * 40 + "\n"
    
    report += f"""
总结:
共监控 {len(stock_data)} 只股票
分析时间: {current_time}

操作建议:
1. 平安银行: 银行股防御性配置，可继续持有
2. 比亚迪: 新能源汽车龙头，关注销量数据
3. 石英股份: 光伏材料，关注行业景气度
4. 中国平安: 保险龙头，估值低位
5. 三星医疗: 医疗设备，稳健增长

风险提示:
以上分析仅供参考，投资需谨慎。
"""
    
    return report

def save_report_file(content):
    """保存报告到文件"""
    try:
        # 创建文件名
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        filename = f"stock_report_{timestamp}.txt"
        
        # 写入文件
        with open(filename, 'w', encoding='utf-8') as f:
            f.write(content)
        
        print(f"✅ 报告文件已保存: {filename}")
        print(f"   文件大小: {len(content)} 字节")
        return filename
    except Exception as e:
        print(f"❌ 保存报告文件失败: {e}")
        return None

def send_wechat_notification(content, token):
    """发送微信通知"""
    if not token or token == "YOUR_PUSHPLUS_TOKEN":
        print("⚠️ 未设置有效的WECHAT_TOKEN，跳过微信推送")
        return False
    
    print("\n6. 发送微信通知...")
    
    try:
        url = "https://www.pushplus.plus/send"
        
        data = {
            "token": token,
            "title": f"📈 股票分析 {datetime.now().strftime('%H:%M')}",
            "content": content.replace('\n', '<br>'),
            "template": "html",
            "topic": "stock"
        }
        
        print(f"   正在发送请求到PushPlus...")
        response = requests.post(url, json=data, timeout=15)
        
        print(f"   响应状态码: {response.status_code}")
        
        if response.status_code == 200:
            result = response.json()
            if result.get('code') == 200:
                print("✅ 微信推送成功！")
                return True
            else:
                print(f"❌ 推送失败: {result.get('msg', '未知错误')}")
                return False
        else:
            print(f"❌ HTTP错误: {response.status_code}")
            print(f"   响应内容: {response.text[:200]}")
            return False
            
    except Exception as e:
        print(f"❌ 发送微信通知异常: {type(e).__name__}: {str(e)}")
        return False

