                    results.append({
                        '名称': stock['name'],
                        '代码': stock['code'],
                        '最新价': 0.0,
                        '涨跌幅': 0.0,
                        '涨跌额': 0.0,
                        '成交量': '0',
                        '成交额': '0',
                        '最高': 0.0,
                        '最低': 0.0
                    })
            except Exception as e:
                print(f"   处理股票 {stock['code']} 时出错: {e}")
                
    except Exception as e:
