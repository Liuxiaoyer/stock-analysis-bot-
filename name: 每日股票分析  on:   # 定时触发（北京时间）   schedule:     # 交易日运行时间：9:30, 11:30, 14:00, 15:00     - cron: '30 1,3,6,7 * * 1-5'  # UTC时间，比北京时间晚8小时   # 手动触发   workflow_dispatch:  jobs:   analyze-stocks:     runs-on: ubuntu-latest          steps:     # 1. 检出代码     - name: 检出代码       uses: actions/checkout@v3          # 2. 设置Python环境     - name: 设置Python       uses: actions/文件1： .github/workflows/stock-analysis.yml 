name: 每日股票分析

on:
  # 定时触发（北京时间）
  schedule:
    # 交易日运行时间：9:30, 11:30, 14:00, 15:00
    - cron: '30 1,3,6,7 * * 1-5'  # UTC时间，比北京时间晚8小时
  # 手动触发
  workflow_dispatch:

jobs:
  analyze-stocks:
    runs-on: ubuntu-latest
    
    steps:
    # 1. 检出代码
    - name: 检出代码
      uses: actions/checkout@v3
    
    # 2. 设置Python环境
    - name: 设置Python
      uses: actions/setup-python@v4
      with:
        python-version: '3.10'
    
    # 3. 安装依赖
    - name: 安装依赖
      run: |
        pip install requests pandas
        pip install akshare --upgrade
    
    # 4. 运行分析脚本
    - name: 运行股票分析
      env:
        WECHAT_TOKEN: ${{ secrets.WECHAT_TOKEN }}
        DEEPSEEK_API_KEY: ${{ secrets.DEEPSEEK_API_KEY }}
      run: python stock_analysis.py
    
    # 5. 上传分析报告
    - name: 上传报告文件
      uses: actions/upload-artifact@v3
      with:
        name: stock-report
        path: stock_report_*.txt
